// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  ADMIN
  STAFF
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
}

enum FollowUpMethod {
  WHATSAPP
  PHONE_CALL
  EMAIL
}

enum VisitStatus {
  PENDING
  COMPLETED
  RESCHEDULED
  CANCELLED
}

// --- MODELS ---

model Department {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., 'Sales', 'Installation', etc.
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String
  phoneNumber  String?
  role         Role        @default(STAFF)
  isActive     Boolean     @default(true)
  
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  uploadedDocuments Document[] @relation("StaffDocuments")

  // Relations (Disambiguated for when a user creates vs is assigned)
  createdLeads       Lead[]        @relation("LeadCreator")
  assignedLeads      Lead[]        @relation("LeadAssignee")
  createdVisits      Visit[]       @relation("VisitCreator")
  assignedVisits     Visit[]       @relation("VisitAssignee")
  followUpsPerformed FollowUp[]
  activityLogs       ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Lead {
  id             String     @id @default(uuid())
  customerName   String
  phoneNumber    String
  email          String?
  address        String?
  leadSource     String?
  requirements   String?
  notes          String?
  status         LeadStatus @default(NEW)

  assignedToId   String?
  assignedTo     User?      @relation("LeadAssignee", fields: [assignedToId], references: [id])
  
  documents Document[] @relation("LeadDocuments")

  createdById    String?
  createdBy      User?      @relation("LeadCreator", fields: [createdById], references: [id])

  followUps      FollowUp[]
  visits         Visit[]
  quotations     Quotation[]   // <-- YOU MUST ADD THIS LINE
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([customerName])
  @@index([phoneNumber])
}

model FollowUp {
  id               String         @id @default(uuid())
  method           FollowUpMethod
  remarks          String?
  nextFollowUpDate DateTime?
  
  leadId           String
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  performedById    String?
  performedBy      User?          @relation(fields: [performedById], references: [id])

  createdAt        DateTime       @default(now())
}

model Visit {
  id              String      @id @default(uuid())
  customerName    String
  phoneNumber     String
  address         String
  visitDatetime   DateTime
  purpose         String
  status          VisitStatus @default(PENDING)

  // Link to a lead if applicable, but can be standalone for existing customers
  leadId          String?
  lead            Lead?       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assignedStaffId String?
  assignedStaff   User?       @relation("VisitAssignee", fields: [assignedStaffId], references: [id])

  // Post-Visit Updates
  comments          String?
  customerFeedback  String?
  workCompleted     String?
  issuesIdentified  String?
  nextSteps         String?

  // Site photos (uploaded via the photo modal)
  documents         Document[]  @relation("VisitDocuments")

  createdById     String?
  createdBy       User?       @relation("VisitCreator", fields: [createdById], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerName])
  @@index([phoneNumber])
}

model ActivityLog {
  id         String   @id @default(uuid())
  actionType String   // e.g., 'LEAD_CREATED', 'VISIT_STATUS_UPDATED'
  entityType String   // e.g., 'LEAD', 'VISIT', 'USER'
  entityId   String   // The ID of the affected record
  details    Json?    // Stores flexible payload like {"old_status": "PENDING", "new_status": "COMPLETED"}

  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
}


// Enums based on your dropdown options
enum PanelType {
  TOPCON
  MONOFACIAL
}

enum DcrStatus {
  DCR
  NON_DCR // Assuming there might be a Non-DCR option, adjust if needed
}

// Enum for the 4 identical dropdowns
enum ComponentBrand {
  HAVELLS_V_GUARD    @map("Havells / V Guard")
  HAVELLS_POLYCAB    @map("Havells/Polycab")
  V_GUARD            @map("V Guard")
  HAVELLS            @map("Havells")
  RR_KABLE           @map("RR KABLE")
}

model Quotation {
  id                    String          @id @default(uuid())
  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // Existing fields
  amount                Float?          // You might want to remove this if 'quotationValue' replaces it entirely
  description           String?

  // --- New Fields from UI ---

  // Panel Details
  panelName             String?
  panelType             PanelType?
  panelWarrantyYears    Int?
  panelSizeWatt         String?         // Stored as String to support ranges like "550 - 575" or "535 - 550"
  numberOfPanels        Int?
  
  // System Specifications
  loadKw                Float?
  structure             String?
  inverterSizeKw        Float?
  inverterWarrantyYears Int?
  
  // Financial & Compliance
  quotationValue        Float?          
  dcrStatus             DcrStatus?      @default(DCR)
  subsidy               Float?
  
  // Cabling Specifications
  dcCableSqMm           Float?
  acCableSqMm           Float?
  
  // 4 Dropdowns with shared brand options
  acWire                ComponentBrand?
  dcWire                ComponentBrand?
  acdbCompany           ComponentBrand?
  dcdbCompany           ComponentBrand?

  // Timestamps
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}


model Document {
  id          String   @id @default(uuid())
  
  // Cloudinary Data
  url         String
  publicId    String   @unique
  format      String   // e.g., 'pdf', 'png'
  bytes       Int      // Size in bytes
  
  // Organization
  category    String   // e.g., 'INVOICE', 'SITE_MAP', 'ID_PROOF'
  
  // Who uploaded this? (Staff / Admin)
  uploadedById String
  uploadedBy   User     @relation("StaffDocuments", fields: [uploadedById], references: [id])

  // --- CRM Relations (Optional attachments) ---
  
  leadId      String?
  lead        Lead?    @relation("LeadDocuments", fields: [leadId], references: [id], onDelete: Cascade)

  visitId     String?
  visit       Visit?   @relation("VisitDocuments", fields: [visitId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Indexes for hyper-fast lookups
  @@index([category])
  @@index([uploadedById])
  @@index([leadId])
  @@index([visitId])
}